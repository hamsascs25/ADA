#include <stdio.h>
int main()
{
    int n, i, j;
    printf("Enter number of vertices: ");
    scanf("%d", &n);
    int adj[n][n], indegree[n], queue[n], top[n];
    printf("Enter adjacency matrix:\n");
    for(i = 0; i < n; i++)
    { indegree[i] = 0;
        for(j = 0; j < n; j++)
        {
          scanf("%d", &adj[i][j]);
            if(adj[i][j] == 1)
            {
                indegree[j]++;
            }
        }
    }
    int front = 0, rear = -1;
    for(i = 0; i < n; i++)
    {
        if(indegree[i] == 0)
        {
            queue[++rear] = i;
        }
    }
    int k = 0;
    while(front <= rear)
    {
        int u = queue[front++];
        top[k++] = u;
        for(i = 0; i < n; i++)
        {
            if(adj[u][i] == 1)
            {
                indegree[i]--
                if(indegree[i] == 0)
                {
                    queue[++rear] = i;
                }
            }
        }
    }
    if(k != n)
    {
        printf("Topological ordering not possible\n");
    }
    else
    {
        printf("Topological Ordering:\n");

        for(i = 0; i < n; i++)
        {
            printf("%d ", top[i]);
        }
    }
    return 0;
}
